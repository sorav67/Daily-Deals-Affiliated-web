generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // The url line has been removed from here!
}

model Deal {
  id           String   @id @default(cuid())
  title        String
  content      String?  
  affiliateUrl String   
  platform     String   
  imageUrl     String?  
  createdAt    DateTime @default(now())
}